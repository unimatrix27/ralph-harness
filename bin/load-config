#!/usr/bin/env bash
#
# load-config — validate a target repo's .ralph/config.yaml.
#
# Usage: load-config <path-to-config.yaml>
#
# Exits 0 on valid input; non-zero with a human-readable error on bad input.
# Thin CLI wrapper around lib/target-config-schema.sh.

set -euo pipefail

HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=../lib/target-config-schema.sh
source "${HERE}/lib/target-config-schema.sh"

tcs::validate "${1:-}"
printf 'ok: %s is a valid .ralph/config.yaml\n' "$1"
