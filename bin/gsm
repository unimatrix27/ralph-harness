#!/usr/bin/env bash
#
# gsm — CLI wrapper around lib/github-state-mutator.sh, useful for manual
# verification against a sandbox repo.
#
# Usage:
#   gsm swap-label <repo> <issue#> <from-label> <to-label>
#   gsm comment-issue <repo> <issue#> <body>
#   gsm find-or-create-log <repo> <milestone>
#   gsm append-caveman-log <repo> <log#> <issue#> <summary> [<gotcha>]

set -euo pipefail

HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=../lib/github-state-mutator.sh
source "${HERE}/lib/github-state-mutator.sh"

usage() {
    cat <<'EOF' >&2
usage: gsm <command> [args]

commands:
  swap-label <repo> <issue#> <from-label> <to-label>
  comment-issue <repo> <issue#> <body>
  find-or-create-log <repo> <milestone>
  append-caveman-log <repo> <log#> <issue#> <summary> [<gotcha>]
EOF
}

cmd="${1:-}"
[[ -z "$cmd" ]] && { usage; exit 2; }
shift

case "$cmd" in
    swap-label)         gsm::swap_label "$@" ;;
    comment-issue)      gsm::comment_issue "$@" ;;
    find-or-create-log) gsm::find_or_create_milestone_log_issue "$@" ;;
    append-caveman-log) gsm::append_caveman_log "$@" ;;
    -h|--help|help)     usage; exit 0 ;;
    *) printf 'gsm: unknown command: %s\n' "$cmd" >&2; usage; exit 2 ;;
esac
