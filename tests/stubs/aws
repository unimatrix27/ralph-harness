#!/usr/bin/env bash
#
# Test stub for `aws`. Records every invocation to $AWS_STUB_LOG (one block
# per call, one arg per line) and emits canned stdout / exit code controlled
# by env vars keyed on the service+operation pair (e.g. `aws kms describe-key`
# uses keys `AWS_STUB_OUT_KMS_DESCRIBE_KEY` / `AWS_STUB_EXIT_KMS_DESCRIBE_KEY`).
#
# The first two non-flag positional args after any leading global flags
# (--region, --profile, --output) form the key. Hyphens become underscores
# and the result is uppercased.
#
# Calls that don't yield a 2-arg key fall back to AWS_STUB_OUT / AWS_STUB_EXIT.

if [[ -n "${AWS_STUB_LOG:-}" ]]; then
    {
        printf '=== aws call ===\n'
        printf 'argc=%s\n' "$#"
        for a in "$@"; do
            printf 'arg=%s\n' "$a"
        done
    } >> "$AWS_STUB_LOG"
fi

# Walk args, skipping global flags and their values, until we have two
# non-flag positionals.
service=""
op=""
skip_next=0
for a in "$@"; do
    if (( skip_next )); then skip_next=0; continue; fi
    case "$a" in
        --region|--profile|--output|--query|--cli-input-json|--endpoint-url)
            skip_next=1
            continue
            ;;
        --*)
            continue
            ;;
        *)
            if [[ -z "$service" ]]; then
                service="$a"
            elif [[ -z "$op" ]]; then
                op="$a"
                break
            fi
            ;;
    esac
done

key=""
if [[ -n "$service" && -n "$op" ]]; then
    key=$(printf '%s_%s' "$service" "$op" | tr '[:lower:]-' '[:upper:]_')
fi

out_var="AWS_STUB_OUT_${key:-DEFAULT}"
exit_var="AWS_STUB_EXIT_${key:-DEFAULT}"

if [[ -n "${!out_var:-}" ]]; then
    printf '%s\n' "${!out_var}"
elif [[ -n "${AWS_STUB_OUT:-}" ]]; then
    printf '%s\n' "$AWS_STUB_OUT"
fi

exit "${!exit_var:-${AWS_STUB_EXIT:-0}}"
